@page
@model FirstMediaVoucher.Pages.Admin.CreateModel
@{
    ViewData["Title"] = "Tambah Voucher Baru - Admin Dashboard";
}

<div class="flex-grow bg-slate-50 py-10">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <!-- Back Link -->
        <div class="mb-6">
            <a asp-page="/Admin/Index" class="inline-flex items-center gap-2 text-sm font-semibold text-slate-500 hover:text-slate-800 transition">
                <i data-lucide="arrow-left" class="w-4 h-4"></i>
                Kembali ke Dashboard
            </a>
        </div>

        <!-- Form Card -->
        <div class="bg-white rounded-3xl border border-slate-150 shadow-sm overflow-hidden relative">
            <div class="h-2 bg-gradient-to-r from-brand-red to-orange-500"></div>

            <div class="p-8 sm:p-10">
                <div class="mb-8">
                    <h1 class="text-2xl font-bold text-slate-900 tracking-tight">Tambah Voucher Baru</h1>
                    <p class="text-xs text-slate-400 mt-1">Masukkan rincian voucher promosi untuk ditambahkan langsung ke katalog penonton.</p>
                </div>

                <form method="post" class="space-y-6">
                    <!-- Validation Summary -->
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="p-4 rounded-2xl bg-rose-50 border border-rose-100 text-rose-800 text-xs flex gap-2.5">
                            <i data-lucide="alert-circle" class="w-4 h-4 shrink-0 mt-0.5 text-brand-red"></i>
                            <div>
                                <p class="font-bold">Mohon perbaiki kesalahan berikut:</p>
                                <div asp-validation-summary="All" class="mt-1 list-disc list-inside text-[11px] text-rose-600"></div>
                            </div>
                        </div>
                    }

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <!-- Partner Name -->
                        <div class="space-y-1.5">
                            <label for="PartnerName" class="block text-[10px] font-bold uppercase tracking-wider text-slate-400">Nama Mitra (Partner)</label>
                            <input type="text" asp-for="Voucher.PartnerName" id="PartnerName" placeholder="Contoh: Starbucks Coffee" required
                                   class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-brand-red focus:ring-4 focus:ring-brand-red/15 transition-all text-sm text-slate-800 placeholder-slate-350" />
                            <span asp-validation-for="Voucher.PartnerName" class="text-xs text-brand-red font-medium"></span>
                        </div>

                        <!-- Category -->
                        <div class="space-y-1.5">
                            <label for="Category" class="block text-[10px] font-bold uppercase tracking-wider text-slate-400">Kategori</label>
                            <select asp-for="Voucher.Category" id="Category" required
                                    class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-brand-red focus:ring-4 focus:ring-brand-red/15 transition-all text-sm text-slate-800 bg-white">
                                <option value="F&B">F&B (Makanan & Minuman)</option>
                                <option value="Entertainment">Entertainment (Hiburan)</option>
                                <option value="Shopping">Shopping (Belanja)</option>
                                <option value="Transport">Transport (Transportasi)</option>
                                <option value="Lainnya">Lainnya</option>
                            </select>
                            <span asp-validation-for="Voucher.Category" class="text-xs text-brand-red font-medium"></span>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <!-- Voucher Title -->
                        <div class="space-y-1.5">
                            <label for="Title" class="block text-[10px] font-bold uppercase tracking-wider text-slate-400">Judul Promo</label>
                            <input type="text" asp-for="Voucher.Title" id="Title" placeholder="Contoh: Beli 1 Gratis 1 Latte" required
                                   class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-brand-red focus:ring-4 focus:ring-brand-red/15 transition-all text-sm text-slate-800 placeholder-slate-350" />
                            <span asp-validation-for="Voucher.Title" class="text-xs text-brand-red font-medium"></span>
                        </div>

                        <!-- Discount Amount -->
                        <div class="space-y-1.5">
                            <label for="DiscountAmount" class="block text-[10px] font-bold uppercase tracking-wider text-slate-400">Nilai Diskon</label>
                            <input type="text" asp-for="Voucher.DiscountAmount" id="DiscountAmount" placeholder="Contoh: 30% OFF / Rp 50.000 OFF" required
                                   class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-brand-red focus:ring-4 focus:ring-brand-red/15 transition-all text-sm text-slate-800 placeholder-slate-350" />
                            <span asp-validation-for="Voucher.DiscountAmount" class="text-xs text-brand-red font-medium"></span>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <!-- Redeem Code -->
                        <div class="space-y-1.5">
                            <label for="RedeemCode" class="block text-[10px] font-bold uppercase tracking-wider text-slate-400">Kode Redeem</label>
                            <input type="text" asp-for="Voucher.RedeemCode" id="RedeemCode" placeholder="Contoh: FMSTARBUCKS30" required
                                   class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-brand-red focus:ring-4 focus:ring-brand-red/15 transition-all text-sm font-mono tracking-wider text-slate-800 placeholder-slate-350 uppercase" />
                            <span asp-validation-for="Voucher.RedeemCode" class="text-xs text-brand-red font-medium"></span>
                        </div>

                        <!-- Expiry Date -->
                        <div class="space-y-1.5">
                            <label for="ExpiryDate" class="block text-[10px] font-bold uppercase tracking-wider text-slate-400">Tanggal Kedaluwarsa</label>
                            <input type="date" asp-for="Voucher.ExpiryDate" id="ExpiryDate" required
                                   class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-brand-red focus:ring-4 focus:ring-brand-red/15 transition-all text-sm text-slate-800 bg-white" />
                            <span asp-validation-for="Voucher.ExpiryDate" class="text-xs text-brand-red font-medium"></span>
                        </div>
                    </div>

                    <!-- Description -->
                    <div class="space-y-1.5">
                        <label for="Description" class="block text-[10px] font-bold uppercase tracking-wider text-slate-400">Deskripsi Promo</label>
                        <textarea asp-for="Voucher.Description" id="Description" rows="3" placeholder="Jelaskan detail penawaran menarik ini..." required
                                  class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-brand-red focus:ring-4 focus:ring-brand-red/15 transition-all text-sm text-slate-800 placeholder-slate-350"></textarea>
                        <span asp-validation-for="Voucher.Description" class="text-xs text-brand-red font-medium"></span>
                    </div>

                    <!-- Terms & Conditions (Newline separated) -->
                    <div class="space-y-1.5">
                        <label for="RawTerms" class="block text-[10px] font-bold uppercase tracking-wider text-slate-400">Syarat & Ketentuan</label>
                        <textarea asp-for="RawTerms" id="RawTerms" rows="4" placeholder="Masukkan syarat & ketentuan, buat 1 baris untuk setiap poin..." required
                                  class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-brand-red focus:ring-4 focus:ring-brand-red/15 transition-all text-sm text-slate-800 placeholder-slate-350"></textarea>
                        <span asp-validation-for="RawTerms" class="text-xs text-brand-red font-medium"></span>
                        <p class="text-[10px] text-slate-400">Tips: Tekan tombol 'Enter' untuk membuat poin syarat baru.</p>
                    </div>

                    <!-- Image URL -->
                    <div class="space-y-2">
                        <label for="ImageUrl" class="block text-[10px] font-bold uppercase tracking-wider text-slate-400">URL Gambar Voucher</label>
                        <input type="url" asp-for="Voucher.ImageUrl" id="ImageUrl" required
                               class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-brand-red focus:ring-4 focus:ring-brand-red/15 transition-all text-sm text-slate-850 placeholder-slate-350" />
                        <span asp-validation-for="Voucher.ImageUrl" class="text-xs text-brand-red font-medium"></span>
                        
                        <!-- Quick Image Templates (Demo Helper) -->
                        <div class="bg-slate-50 p-4 rounded-xl border border-slate-200 mt-2 space-y-2">
                            <span class="block text-[10px] font-bold uppercase tracking-wider text-slate-500">Gunakan Template Gambar Demo</span>
                            <div class="flex flex-wrap gap-2">
                                <button type="button" onclick="setImage('coffee')" class="px-3 py-1.5 text-[10px] font-bold bg-white border border-slate-200 rounded-lg hover:bg-slate-100 hover:text-slate-900 transition cursor-pointer">☕ F&B (Kopi)</button>
                                <button type="button" onclick="setImage('cinema')" class="px-3 py-1.5 text-[10px] font-bold bg-white border border-slate-200 rounded-lg hover:bg-slate-100 hover:text-slate-900 transition cursor-pointer">🍿 Hiburan (Bioskop)</button>
                                <button type="button" onclick="setImage('shopping')" class="px-3 py-1.5 text-[10px] font-bold bg-white border border-slate-200 rounded-lg hover:bg-slate-100 hover:text-slate-900 transition cursor-pointer">🛍️ Belanja (Shopping)</button>
                                <button type="button" onclick="setImage('travel')" class="px-3 py-1.5 text-[10px] font-bold bg-white border border-slate-200 rounded-lg hover:bg-slate-100 hover:text-slate-900 transition cursor-pointer">🚗 Transportasi (Grab)</button>
                            </div>
                        </div>
                    </div>

                    <!-- Submit Button -->
                    <button type="submit" class="w-full py-4 px-4 text-xs font-bold text-white bg-slate-900 hover:bg-brand-red active:scale-95 transition-all duration-200 rounded-xl shadow-md cursor-pointer flex items-center justify-center gap-1.5">
                        <i data-lucide="save" class="w-4 h-4"></i>
                        Simpan & Publikasikan Voucher
                    </button>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        function setImage(type) {
            const urls = {
                coffee: 'https://images.unsplash.com/photo-1544787219-7f47ccb76574?w=500&auto=format&fit=crop&q=80',
                cinema: 'https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?w=500&auto=format&fit=crop&q=80',
                shopping: 'https://images.unsplash.com/photo-1607082348824-0a96f2a4b9da?w=500&auto=format&fit=crop&q=80',
                travel: 'https://images.unsplash.com/photo-1549317661-bd32c8ce0db2?w=500&auto=format&fit=crop&q=80'
            };
            
            if (urls[type]) {
                document.getElementById('ImageUrl').value = urls[type];
            }
        }
    </script>
}

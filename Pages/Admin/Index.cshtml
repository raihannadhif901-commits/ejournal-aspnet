@page
@model FirstMediaVoucher.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Dashboard Admin - Manajemen Voucher";
}

<div class="flex-grow bg-slate-50 py-10">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <!-- Header -->
        <div class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-4">
            <div>
                <span class="text-xs font-bold text-brand-orange uppercase tracking-widest block mb-1 font-space">Manajemen Konten & Telemetri</span>
                <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight font-space leading-none">Dashboard Admin</h1>
                <p class="text-sm text-slate-450 mt-2">Pantau statistik klik dan kelola voucher promosi Privilege First Media.</p>
            </div>
            
            <a asp-page="/Admin/Create" class="inline-flex items-center justify-center px-5 py-3 text-xs font-bold text-white bg-slate-900 hover:bg-brand-orange active:scale-95 transition-all duration-200 rounded-xl shadow-sm gap-1.5 cursor-pointer font-space">
                <i data-lucide="plus" class="w-4 h-4"></i>
                Tambah Voucher Baru
            </a>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="mb-6 p-4 rounded-xl bg-emerald-50 border border-emerald-100 text-emerald-800 text-xs flex gap-2.5 items-start">
                <i data-lucide="check-circle" class="w-4 h-4 text-emerald-600 mt-0.5"></i>
                <span class="font-semibold">@TempData["SuccessMessage"]</span>
            </div>
        }

        <!-- 1. METRICS / STAT CARDS GRID -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8 font-space">
            <!-- Stat 1: Total Vouchers -->
            <div class="bg-white rounded-2xl border border-orange-100/35 p-6 shadow-sm flex items-center gap-4">
                <div class="p-3.5 rounded-xl bg-orange-50 text-brand-orange border border-orange-100/50">
                    <i data-lucide="tag" class="w-6 h-6"></i>
                </div>
                <div>
                    <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider block">Total Voucher</span>
                    <span class="text-2xl font-black text-slate-800">@Model.TotalVouchers</span>
                </div>
            </div>

            <!-- Stat 2: Total Clicks -->
            <div class="bg-white rounded-2xl border border-orange-100/35 p-6 shadow-sm flex items-center gap-4">
                <div class="p-3.5 rounded-xl bg-orange-50 text-brand-orange border border-orange-100/50">
                    <i data-lucide="mouse-pointer-click" class="w-6 h-6"></i>
                </div>
                <div>
                    <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider block">Total Klik / Reveal</span>
                    <span class="text-2xl font-black text-slate-800">@Model.TotalClicks</span>
                </div>
            </div>

            <!-- Stat 3: Most Popular -->
            <div class="bg-white rounded-2xl border border-orange-100/35 p-6 shadow-sm flex items-center gap-4">
                <div class="p-3.5 rounded-xl bg-orange-50 text-brand-orange border border-orange-100/50">
                    <i data-lucide="award" class="w-6 h-6"></i>
                </div>
                <div class="min-w-0">
                    <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider block">Mitra Terpopuler</span>
                    <span class="text-base font-black text-slate-800 truncate block mt-0.5">@Model.MostPopularPartner</span>
                </div>
            </div>
        </div>

        <!-- 2. GRAPH / CHARTS GRID -->
        <div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-10">
            <!-- Chart 1: Bar Chart (8 cols) -->
            <div class="md:col-span-7 bg-white rounded-2xl border border-orange-100/35 p-6 shadow-sm flex flex-col gap-4">
                <h3 class="text-sm font-bold text-slate-800 uppercase tracking-wider font-space border-b border-orange-50 pb-3 flex items-center gap-2">
                    <i data-lucide="bar-chart-3" class="w-4 h-4 text-brand-orange"></i>
                    Top 5 Voucher Terpopuler
                </h3>
                <div class="relative h-64 w-full">
                    <canvas id="barChart"></canvas>
                </div>
            </div>

            <!-- Chart 2: Doughnut Chart (5 cols) -->
            <div class="md:col-span-5 bg-white rounded-2xl border border-orange-100/35 p-6 shadow-sm flex flex-col gap-4">
                <h3 class="text-sm font-bold text-slate-800 uppercase tracking-wider font-space border-b border-orange-50 pb-3 flex items-center gap-2">
                    <i data-lucide="pie-chart" class="w-4 h-4 text-brand-orange"></i>
                    Porsi Klik Per Kategori Promo
                </h3>
                <div class="relative h-64 w-full flex items-center justify-center">
                    <canvas id="doughnutChart"></canvas>
                </div>
            </div>
        </div>

        <!-- 3. VOUCHER LIST TABLE -->
        <div class="bg-white rounded-2xl border border-orange-100/35 shadow-sm overflow-hidden">
            <div class="p-6 border-b border-orange-50 bg-slate-50/50">
                <h3 class="text-sm font-bold text-slate-800 uppercase tracking-wider font-space flex items-center gap-2">
                    <i data-lucide="list" class="w-4 h-4 text-brand-orange"></i>
                    Daftar Semua Voucher Aktif
                </h3>
            </div>
            
            @if (Model.Vouchers.Count == 0)
            {
                <div class="p-12 text-center text-slate-400 space-y-3">
                    <i data-lucide="folder-open" class="w-10 h-10 mx-auto text-slate-300"></i>
                    <h4 class="font-bold text-slate-800 text-sm">Belum Ada Voucher</h4>
                    <p class="text-xs">Database kosong. Klik tombol 'Tambah Voucher Baru' untuk menginput voucher promosi pertama Anda.</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-100 text-left text-xs">
                        <thead class="bg-slate-50/80 font-bold text-slate-500 text-[10px] uppercase tracking-wider font-space">
                            <tr>
                                <th class="px-6 py-4">Voucher / Partner</th>
                                <th class="px-6 py-4">Kategori</th>
                                <th class="px-6 py-4">Nilai Diskon</th>
                                <th class="px-6 py-4">Kode Redeem</th>
                                <th class="px-6 py-4">Klik / Reveal</th>
                                <th class="px-6 py-4">Kedaluwarsa</th>
                                <th class="px-6 py-4 text-right">Aksi</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 text-slate-650 bg-white">
                            @foreach (var voucher in Model.Vouchers)
                            {
                                <tr>
                                    <!-- Image & Partner & Title -->
                                    <td class="px-6 py-4 flex items-center gap-3">
                                        <div class="w-12 h-12 rounded-xl overflow-hidden border border-slate-100 bg-slate-100 shrink-0 shadow-sm">
                                            <img src="@voucher.ImageUrl" alt="@voucher.PartnerName" class="w-full h-full object-cover" />
                                        </div>
                                        <div>
                                            <div class="font-bold text-slate-800 text-sm font-space">@voucher.PartnerName</div>
                                            <div class="text-[10px] text-slate-455 mt-0.5 max-w-xs truncate">@voucher.Title</div>
                                        </div>
                                    </td>
                                    
                                    <!-- Category -->
                                    <td class="px-6 py-4 font-bold text-slate-500">
                                        @voucher.Category
                                    </td>
                                    
                                    <!-- Discount -->
                                    <td class="px-6 py-4 font-bold text-brand-orange font-space">
                                        @voucher.DiscountAmount
                                    </td>
                                    
                                    <!-- Redeem Code -->
                                    <td class="px-6 py-4 font-mono font-bold text-slate-700">
                                        @voucher.RedeemCode
                                    </td>

                                    <!-- Click Counter -->
                                    <td class="px-6 py-4 font-bold text-slate-750 font-space text-sm">
                                        @(voucher.ClickCount)x
                                    </td>
                                    
                                    <!-- Expiry Date -->
                                    <td class="px-6 py-4 font-medium text-slate-500">
                                        @voucher.ExpiryDate.ToString("dd MMM yyyy")
                                    </td>
                                    
                                    <!-- Action -->
                                    <td class="px-6 py-4 text-right">
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@voucher.Id" 
                                              onsubmit="return confirm('Apakah Anda yakin ingin menghapus voucher @voucher.PartnerName - @voucher.Title?')" 
                                              class="inline">
                                            <button type="submit" class="p-2 text-slate-400 hover:text-brand-orange hover:bg-slate-50 rounded-lg transition cursor-pointer" title="Hapus Voucher">
                                                <i data-lucide="trash-2" class="w-4 h-4"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
        
    </div>
</div>

@section Scripts {
    <!-- Include Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <script>
        // Fetch Serialized Data from Code-Behind Model
        const topVoucherLabels = @Html.Raw(Json.Serialize(Model.TopVoucherLabels));
        const topVoucherClicks = @Html.Raw(Json.Serialize(Model.TopVoucherClicks));
        
        const categoryLabels = @Html.Raw(Json.Serialize(Model.CategoryLabels));
        const categoryClicks = @Html.Raw(Json.Serialize(Model.CategoryClicks));

        // 1. Render Bar Chart (Top Vouchers)
        const ctxBar = document.getElementById('barChart').getContext('2d');
        new Chart(ctxBar, {
            type: 'bar',
            data: {
                labels: topVoucherLabels.length > 0 ? topVoucherLabels : ['Belum Ada Data'],
                datasets: [{
                    label: 'Jumlah Penyingkapan Kode (Klik)',
                    data: topVoucherClicks.length > 0 ? topVoucherClicks : [0],
                    backgroundColor: 'rgba(249, 115, 22, 0.75)', // Linknet Orange
                    borderColor: 'rgb(249, 115, 22)',
                    borderWidth: 1.5,
                    borderRadius: 8,
                    borderSkipped: false
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { stepSize: 1, color: '#94A3B8', font: { family: 'Plus Jakarta Sans' } },
                        grid: { borderDash: [4, 4], color: '#E2E8F0' }
                    },
                    x: {
                        ticks: { color: '#64748B', font: { family: 'Plus Jakarta Sans', weight: 'bold' } },
                        grid: { display: false }
                    }
                }
            }
        });

        // 2. Render Doughnut Chart (Categories)
        const ctxDoughnut = document.getElementById('doughnutChart').getContext('2d');
        new Chart(ctxDoughnut, {
            type: 'doughnut',
            data: {
                labels: categoryLabels.length > 0 ? categoryLabels : ['Belum Ada Data'],
                datasets: [{
                    data: categoryClicks.length > 0 ? categoryClicks : [0],
                    backgroundColor: [
                        '#F97316', // Orange
                        '#E11D48', // Red
                        '#F59E0B', // Gold/Amber
                        '#10B981', // Emerald
                        '#6366F1'  // Indigo
                    ],
                    borderWidth: 2,
                    borderColor: '#FFFFFF'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            color: '#64748B',
                            font: { family: 'Plus Jakarta Sans', size: 11, weight: '600' },
                            padding: 15,
                            usePointStyle: true
                        }
                    }
                },
                cutout: '65%'
            }
        });
    </script>
}

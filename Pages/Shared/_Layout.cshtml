<!DOCTYPE html>
<html lang="en" class="h-full bg-[#FFF9F5]">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - First Media Privilege Vouchers</title>
    <link rel="icon" type="image/png" href="~/icon.png" />
    
    <!-- Google Fonts: Space Grotesk (Headers) & Plus Jakarta Sans (Body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Compiled Tailwind CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="h-full font-jakarta text-slate-800 flex flex-col min-h-screen bg-gradient-to-br from-orange-50/60 via-slate-50 to-orange-100/40">
    <header class="sticky top-0 z-40 w-full border-b border-orange-100/40 bg-white/80 backdrop-blur-md transition-all duration-300">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex h-16 items-center justify-between">
                <!-- Brand Logo -->
                <div class="flex items-center gap-2">
                    <a asp-page="/Index" class="flex items-center focus:outline-none">
                        <img src="~/icon.png" alt="First Media / Linknet Logo" class="h-8 w-auto object-contain" />
                    </a>
                </div>

                <!-- Navigation Links -->
                <div class="flex items-center gap-4">
                    <a asp-page="/Promos" class="text-xs font-bold text-slate-650 hover:text-brand-orange transition flex items-center gap-1 font-space">
                        <i data-lucide="tag" class="w-3.5 h-3.5"></i>
                        Katalog Promo
                    </a>
                    
                    <div class="h-4 w-px bg-orange-100"></div>
                    
                    <a asp-page="/Admin/Index" class="inline-flex items-center justify-center px-4 py-1.5 text-xs font-bold text-slate-700 bg-orange-50 hover:bg-brand-orange-light border border-orange-200/50 transition-all duration-200 rounded-xl font-space">
                        <i data-lucide="settings" class="w-3.5 h-3.5 mr-1 text-brand-orange"></i>
                        Dashboard Admin
                    </a>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content Area -->
    <main class="flex-grow flex flex-col">
        @RenderBody()
    </main>

    <!-- Premium Branded Footer (Google/Antigravity style) -->
    <footer class="bg-white border-t border-orange-100/40 pt-16 pb-8 mt-auto">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
            
            <!-- Upper Section: Simplified Two-column Links -->
            <div class="grid grid-cols-2 gap-16 max-w-md mx-auto mb-12 text-left">
                <!-- Col 1: Privilege -->
                <div class="space-y-3">
                    <h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest font-space">Privilege</h4>
                    <ul class="space-y-2 text-xs font-medium text-slate-500">
                        <li><a asp-page="/Promos" class="hover:text-brand-orange transition">Semua Promo</a></li>
                        <li><a href="#" class="hover:text-brand-orange transition">Syarat & Ketentuan</a></li>
                        <li><a href="#" class="hover:text-brand-orange transition">Kebijakan Privasi</a></li>
                    </ul>
                </div>
                <!-- Col 2: Social Media Icons -->
                <div class="space-y-4">
                    <h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest font-space font-semibold">Ikuti Kami</h4>
                    <div class="flex gap-2.5 text-slate-500">
                        <!-- Instagram -->
                        <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" 
                           class="p-2 rounded-xl border border-slate-200 hover:border-brand-orange hover:text-brand-orange hover:bg-orange-50/50 transition duration-200" title="Instagram">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                                <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
                                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                                <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
                            </svg>
                        </a>
                        <!-- TikTok -->
                        <a href="https://tiktok.com" target="_blank" rel="noopener noreferrer" 
                           class="p-2 rounded-xl border border-slate-200 hover:border-brand-orange hover:text-brand-orange hover:bg-orange-50/50 transition duration-200" title="TikTok">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.02 1.63 4.18 1.12 1.25 2.7 2.05 4.34 2.21v3.91c-1.89-.07-3.75-.72-5.26-1.88-.38-.29-.73-.62-1.05-.97V14.5c0 1.25-.26 2.5-.78 3.65a7.35 7.35 0 0 1-5.18 4.41c-1.39.38-2.85.39-4.24-.01a7.34 7.34 0 0 1-4.7-5.06c-.46-1.58-.38-3.27.24-4.8A7.32 7.32 0 0 1 9.4 8.24V12.2c-.73.27-1.38.74-1.85 1.37a3.42 3.42 0 0 0-.67 2.1c-.02.95.36 1.88 1.05 2.52.74.67 1.73 1.02 2.72.97 1.02-.03 2.01-.58 2.53-1.46.29-.48.43-1.04.42-1.61V.02z"/>
                            </svg>
                        </a>
                        <!-- YouTube -->
                        <a href="https://youtube.com" target="_blank" rel="noopener noreferrer" 
                           class="p-2 rounded-xl border border-slate-200 hover:border-brand-orange hover:text-brand-orange hover:bg-orange-50/50 transition duration-200" title="YouTube">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                                <path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17z"/>
                                <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/>
                            </svg>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Middle Section: Massive Linknet Brand Text -->
            <div class="text-[9.5vw] font-black font-space tracking-tighter text-brand-orange select-none text-center uppercase leading-none my-8 select-none flex justify-center overflow-hidden">
                <span class="animate-slide-up inline-block" style="animation-delay: 0.05s">l</span><span class="animate-slide-up inline-block" style="animation-delay: 0.12s">i</span><span class="animate-slide-up inline-block" style="animation-delay: 0.19s">n</span><span class="animate-slide-up inline-block" style="animation-delay: 0.26s">k</span><span class="animate-slide-up inline-block" style="animation-delay: 0.33s">n</span><span class="animate-slide-up inline-block" style="animation-delay: 0.4s">e</span><span class="animate-slide-up inline-block" style="animation-delay: 0.47s">t</span>
            </div>

            <!-- Lower Section: Legal & Copyright -->
            <div class="border-t border-orange-100/40 pt-6 flex flex-col md:flex-row items-center justify-between gap-4">
                <div class="text-xs font-semibold text-slate-400">
                    &copy; @DateTime.Now.Year PT Link Net Tbk. All rights reserved.
                </div>
                <div class="flex gap-6 text-xs text-slate-400 font-space font-semibold">
                    <a href="#" class="hover:text-brand-orange transition">About Linknet</a>
                    <a href="#" class="hover:text-brand-orange transition">Privacy Policy</a>
                    <a href="#" class="hover:text-brand-orange transition">Terms of Service</a>
                </div>
            </div>

        </div>
    </footer>

    <!-- Initialize Lucide Icons -->
    <script>
        lucide.createIcons();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
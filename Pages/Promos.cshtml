@page
@model FirstMediaVoucher.Pages.PromosModel
@{
    ViewData["Title"] = "Katalog Promo Privilege";
}

<div class="flex-grow py-10 bg-transparent">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <!-- Header Section -->
        <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div>
                <span class="text-xs font-bold text-brand-orange uppercase tracking-widest block mb-1 font-space">First Media Privilege</span>
                <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight font-space leading-none">Katalog Promo & Voucher</h1>
                <p class="text-sm text-slate-500 mt-2">Daftar penawaran eksklusif spesial untuk seluruh pelanggan First Media.</p>
            </div>
            
            <!-- Category Filters -->
            <div class="flex flex-wrap gap-2 font-space">
                <a asp-page="/Promos" asp-route-SelectedCategory="All" asp-route-p="1"
                   class="px-4 py-2 text-xs font-bold rounded-xl border transition-all cursor-pointer @(string.IsNullOrEmpty(Model.SelectedCategory) || Model.SelectedCategory == "All" ? "bg-brand-orange text-white border-brand-orange shadow-sm" : "bg-white text-slate-500 border-slate-200 hover:bg-orange-50 hover:text-brand-orange hover:border-orange-200")">
                    Semua Kategori
                </a>
                @foreach (var category in Model.Categories)
                {
                    <a asp-page="/Promos" asp-route-SelectedCategory="@category" asp-route-p="1"
                       class="px-4 py-2 text-xs font-bold rounded-xl border transition-all cursor-pointer @(Model.SelectedCategory == category ? "bg-brand-orange text-white border-brand-orange shadow-sm" : "bg-white text-slate-500 border-slate-200 hover:bg-orange-50 hover:text-brand-orange hover:border-orange-200")">
                        @category
                    </a>
                }
            </div>
        </div>

        <!-- Voucher Grid -->
        @if (Model.Vouchers.Count == 0)
        {
            <div class="bg-white/80 backdrop-blur-md rounded-3xl border border-orange-100/55 p-12 text-center shadow-sm">
                <div class="w-12 h-12 rounded-full bg-orange-50 text-brand-orange flex items-center justify-center mx-auto mb-4 border border-orange-100/50">
                    <i data-lucide="tag" class="w-5 h-5"></i>
                </div>
                <h3 class="text-base font-bold text-slate-800 font-space">Tidak Ada Promo</h3>
                <p class="text-xs text-slate-400 mt-1">Belum ada promo yang tersedia untuk kategori "@Model.SelectedCategory".</p>
                <a asp-page="/Promos" asp-route-SelectedCategory="All" asp-route-p="1" class="mt-4 inline-flex items-center justify-center px-4 py-2 text-xs font-bold text-slate-700 bg-slate-100 rounded-xl hover:bg-slate-200 transition">
                    Kembali ke Semua Promo
                </a>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                @foreach (var voucher in Model.Vouchers)
                {
                    <div class="group bg-white/90 backdrop-blur-md rounded-2xl border border-orange-100/40 shadow-sm hover:shadow-md hover:border-orange-200/50 hover:-translate-y-0.5 transition-all duration-300 overflow-hidden flex flex-col justify-between">
                        
                        <!-- Voucher Banner Image -->
                        <div class="relative h-44 w-full overflow-hidden bg-slate-100 shrink-0">
                            <img src="@voucher.ImageUrl" alt="@voucher.PartnerName" 
                                 class="w-full h-full object-cover group-hover:scale-103 transition-transform duration-500" />
                            <div class="absolute inset-0 bg-gradient-to-t from-black/25 to-transparent"></div>
                        </div>

                        <!-- Card Body -->
                        <div class="p-5 flex-grow flex flex-col gap-3">
                            <!-- Partner Name & Discount Amount -->
                            <div class="flex justify-between items-start">
                                <div>
                                    <h3 class="text-[10px] font-bold text-slate-400 uppercase tracking-widest font-space">@voucher.PartnerName</h3>
                                    <span class="text-xs font-bold text-brand-orange font-space">@voucher.Category</span>
                                </div>
                                <span class="text-lg font-bold text-slate-900 font-space tracking-tight">
                                    @voucher.DiscountAmount
                                </span>
                            </div>

                            <!-- Title & Description -->
                            <div class="space-y-1">
                                <h2 class="text-base font-bold text-slate-800 leading-snug group-hover:text-brand-orange transition-colors duration-200 line-clamp-1 font-space">
                                    @voucher.Title
                                </h2>
                                <p class="text-xs text-slate-450 line-clamp-2 leading-relaxed">
                                    @voucher.Description
                                </p>
                            </div>

                            <!-- Expiry Info -->
                            <div class="pt-3 border-t border-orange-50 mt-auto flex items-center gap-1.5 text-[10px] font-semibold text-slate-450">
                                <i data-lucide="calendar" class="w-3.5 h-3.5 text-slate-400"></i>
                                <span>Berlaku hingga: <strong class="text-slate-700 font-bold font-space">@voucher.ExpiryDate.ToString("dd MMM yyyy")</strong></span>
                            </div>
                        </div>

                        <!-- Card Action -->
                        <div class="px-5 pb-5 pt-0">
                            <a asp-page="/VoucherDetail" asp-route-id="@voucher.Id" 
                               class="w-full py-2.5 px-4 text-xs font-bold text-center text-slate-750 hover:text-white bg-slate-50 hover:bg-brand-orange border border-slate-200/50 hover:border-brand-orange active:scale-95 transition-all duration-200 rounded-xl flex items-center justify-center gap-1 cursor-pointer font-space">
                                Detail Promo
                                <i data-lucide="chevron-right" class="w-4 h-4"></i>
                            </a>
                        </div>
                    </div>
                }
            </div>

            <!-- Pagination Controls -->
            @if (Model.TotalPages > 1)
            {
                <div class="mt-12 flex justify-center items-center gap-2 font-space">
                    <!-- Previous Page -->
                    @if (Model.PageNumber > 1)
                    {
                        <a asp-page="/Promos" asp-route-SelectedCategory="@Model.SelectedCategory" asp-route-p="@(Model.PageNumber - 1)" 
                           class="w-9 h-9 flex items-center justify-center rounded-xl bg-white border border-slate-200 text-slate-650 hover:bg-orange-50 hover:text-brand-orange hover:border-orange-200 transition shadow-sm cursor-pointer">
                            <i data-lucide="chevron-left" class="w-4 h-4"></i>
                        </a>
                    }
                    else
                    {
                        <span class="w-9 h-9 flex items-center justify-center rounded-xl bg-slate-100/50 border border-slate-150 text-slate-350 select-none">
                            <i data-lucide="chevron-left" class="w-4 h-4"></i>
                        </span>
                    }

                    <!-- Page Numbers -->
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        if (i == Model.PageNumber)
                        {
                            <span class="w-9 h-9 flex items-center justify-center rounded-xl bg-brand-orange border border-brand-orange text-white font-bold shadow-sm select-none">
                                @i
                            </span>
                        }
                        else
                        {
                            <a asp-page="/Promos" asp-route-SelectedCategory="@Model.SelectedCategory" asp-route-p="@i" 
                               class="w-9 h-9 flex items-center justify-center rounded-xl bg-white border border-slate-200 text-slate-650 hover:bg-orange-50 hover:text-brand-orange hover:border-orange-200 transition shadow-sm font-bold cursor-pointer">
                                @i
                            </a>
                        }
                    }

                    <!-- Next Page -->
                    @if (Model.PageNumber < Model.TotalPages)
                    {
                        <a asp-page="/Promos" asp-route-SelectedCategory="@Model.SelectedCategory" asp-route-p="@(Model.PageNumber + 1)" 
                           class="w-9 h-9 flex items-center justify-center rounded-xl bg-white border border-slate-200 text-slate-650 hover:bg-orange-50 hover:text-brand-orange hover:border-orange-200 transition shadow-sm cursor-pointer">
                            <i data-lucide="chevron-right" class="w-4 h-4"></i>
                        </a>
                    }
                    else
                    {
                        <span class="w-9 h-9 flex items-center justify-center rounded-xl bg-slate-100/50 border border-slate-150 text-slate-350 select-none">
                            <i data-lucide="chevron-right" class="w-4 h-4"></i>
                        </span>
                    }
                </div>
            }
        }
    </div>
</div>

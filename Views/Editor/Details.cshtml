@model EJournal.Models.Article
@{
    ViewData["Title"] = "Editor Review Panel";
}

<div class="row">
    <!-- Sidebar navigation -->
    <div class="col-md-3">
        <div class="dashboard-sidebar">
            <h4 class="font-weight-bold text-dark mb-4" style="font-family: var(--serif-font);">Editor Panel</h4>
            <a asp-controller="Editor" asp-action="Dashboard" class="sidebar-nav-link active">Manage Articles</a>
            <a asp-controller="Editor" asp-action="ManageVolumes" class="sidebar-nav-link">Manage Issues</a>
            <hr />
            <a asp-controller="Dashboard" asp-action="Index" class="sidebar-nav-link">Home Dashboard</a>
        </div>
    </div>

    <!-- Main board -->
    <div class="col-md-9">
        <div class="dashboard-card">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Editor" asp-action="Dashboard" class="text-dark">Editor Panel</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Manuscript Processing</li>
                </ol>
            </nav>

            <h2 class="section-title mt-2">Manuscript Processing Desk</h2>

            <div class="row mb-4">
                <div class="col-md-9">
                    <h3 style="font-family: var(--serif-font); font-weight: 700; color: var(--primary-color);">@Model.Title</h3>
                    <p class="text-muted mb-0"><strong>Author:</strong> @(Model.Author?.Name ?? "Unknown") (@Model.Author?.Email)</p>
                    <p class="text-muted small"><strong>Submitted:</strong> @Model.SubmittedAt.ToString("MMMM dd, yyyy HH:mm")</p>
                </div>
                <div class="col-md-3 text-md-end">
                    <span class="status-badge status-@(Model.Status.ToString().ToLower())" style="font-size: 1rem; padding: 0.4rem 1rem;">
                        @Model.Status
                    </span>
                </div>
            </div>

            <!-- PDF Access -->
            <div class="bg-light p-3 rounded mb-4 d-flex justify-content-between align-items-center">
                <span><strong>File:</strong> @Model.FilePath</span>
                <a asp-controller="Archive" asp-action="Download" asp-route-filename="@Model.FilePath" class="btn-secondary-custom btn-sm">
                    Open/Download PDF
                </a>
            </div>

            <!-- Abstract -->
            <h5 class="font-weight-bold text-dark" style="font-family: var(--serif-font);">Abstract:</h5>
            <div class="border p-3 bg-white mb-4 italic" style="border-radius: 4px; font-style: italic;">
                @Model.Abstract
            </div>

            <hr class="my-5" />

            <!-- Review Assignments -->
            <div class="row">
                <div class="col-lg-7">
                    <h4 class="font-weight-bold text-dark mb-3" style="font-family: var(--serif-font);">Peer Review Status</h4>
                    @if (!Model.ReviewAssignments.Any())
                    {
                        <div class="alert alert-secondary">No peer reviewers have been assigned yet.</div>
                    }
                    else
                    {
                        @foreach (var review in Model.ReviewAssignments)
                        {
                            <div class="card mb-3">
                                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                                    <strong class="text-dark">Reviewer: @review.Reviewer?.Name</strong>
                                    @if (review.Status == ReviewStatus.Completed)
                                    {
                                        <span class="status-badge status-accepted">Completed</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-underreview">Pending</span>
                                    }
                                </div>
                                <div class="card-body p-3 small">
                                    @if (review.Status == ReviewStatus.Completed)
                                    {
                                        <p class="mb-1"><strong>Recommendation:</strong> <span class="font-weight-bold text-primary">@review.Recommendation</span></p>
                                        <p class="mb-2"><strong>Date Completed:</strong> @review.CompletedAt?.ToString("yyyy-MM-dd")</p>
                                        <p class="mb-1"><strong>Feedback for Author:</strong></p>
                                        <div class="p-2 border bg-light mb-2">@review.CommentsForAuthor</div>
                                        @if (!string.IsNullOrEmpty(review.CommentsForEditor))
                                        {
                                            <p class="mb-1"><strong>Confidential Notes for Editor:</strong></p>
                                            <div class="p-2 border bg-warning bg-opacity-10 text-dark">@review.CommentsForEditor</div>
                                        }
                                    }
                                    else
                                    {
                                        <p class="mb-0 text-muted">Assigned on @review.AssignedAt.ToString("yyyy-MM-dd"). Waiting for response.</p>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>

                <!-- Reviewer Assignment form -->
                <div class="col-lg-5">
                    @if (Model.Status == ArticleStatus.Submitted || Model.Status == ArticleStatus.UnderReview)
                    {
                        <div class="dashboard-card p-3">
                            <h5 class="font-weight-bold mb-3" style="font-family: var(--serif-font);">Assign New Reviewer</h5>
                            
                            @if (ViewBag.ReviewerId.Items.Count == 0)
                            {
                                <p class="text-muted small">No other reviewers are available to assign.</p>
                            }
                            else
                            {
                                <form asp-controller="Editor" asp-action="AssignReviewer" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="articleId" value="@Model.Id" />
                                    
                                    <div class="form-group-custom">
                                        <label class="form-label-custom" for="reviewerId">Select Peer Reviewer</label>
                                        <select id="reviewerId" name="reviewerId" class="form-input-custom" asp-items="ViewBag.ReviewerId" required>
                                            <option value="">-- Choose Reviewer --</option>
                                        </select>
                                    </div>
                                    <button type="submit" class="btn-primary-custom btn-sm w-100">Assign Reviewer</button>
                                </form>
                            }
                        </div>
                    }
                </div>
            </div>

            <hr class="my-5" />

            <!-- Decisions & Actions Panel -->
            <h4 class="font-weight-bold text-dark mb-3" style="font-family: var(--serif-font);">Editorial Decisions</h4>
            
            <div class="row">
                <!-- Standard decisions (Accept/Reject/Revision) -->
                <div class="col-md-6 mb-3">
                    @if (Model.Status == ArticleStatus.Submitted || Model.Status == ArticleStatus.UnderReview)
                    {
                        <div class="dashboard-card p-3 h-100">
                            <h5 class="font-weight-bold mb-3" style="font-family: var(--serif-font);">Record Decision</h5>
                            
                            <form asp-controller="Editor" asp-action="MakeDecision" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="articleId" value="@Model.Id" />

                                <div class="form-group-custom">
                                    <label class="form-label-custom" for="decision">Decision</label>
                                    <select id="decision" name="decision" class="form-input-custom" required>
                                        <option value="">-- Select Decision --</option>
                                        <option value="Accepted">Accept Submission</option>
                                        <option value="UnderRevision">Request Revisions</option>
                                        <option value="Rejected">Reject Submission</option>
                                    </select>
                                </div>

                                <div class="form-group-custom">
                                    <label class="form-label-custom" for="remarks">Decision Remarks / Feedback</label>
                                    <textarea id="remarks" name="remarks" rows="4" class="form-input-custom" required placeholder="Write detailed feedback explaining the decision or requesting revisions."></textarea>
                                </div>

                                <button type="submit" class="btn-primary-custom btn-sm w-100">Record Editorial Decision</button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No further active decisions are needed for this manuscript stage.</p>
                    }
                </div>

                <!-- Publish Form if status is Accepted -->
                <div class="col-md-6 mb-3">
                    @if (Model.Status == ArticleStatus.Accepted)
                    {
                        <div class="dashboard-card p-3 h-100" style="border: 1px solid #059669;">
                            <h5 class="font-weight-bold mb-3 text-success" style="font-family: var(--serif-font);">Publish Manuscript</h5>
                            
                            <form asp-controller="Editor" asp-action="Publish" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="articleId" value="@Model.Id" />

                                <div class="form-group-custom">
                                    <label class="form-label-custom" for="volumeId">Assign to Volume / Issue</label>
                                    <select id="volumeId" name="volumeId" class="form-input-custom" asp-items="ViewBag.VolumeList" required>
                                        <option value="">-- Choose Volume --</option>
                                    </select>
                                </div>

                                <div class="form-group-custom">
                                    <label class="form-label-custom" for="doi">Digital Object Identifier (DOI)</label>
                                    <input type="text" id="doi" name="doi" class="form-input-custom" placeholder="Leave blank to auto-generate DOI" />
                                </div>

                                <button type="submit" class="btn-primary-custom btn-sm w-100" style="background-color: #059669; border-color: #059669;">
                                    Publish in Archive
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>

            <hr class="my-5" />

            <!-- Log Trails -->
            <h4 class="font-weight-bold text-dark mb-3" style="font-family: var(--serif-font);">Processing Audit Logs</h4>
            <table class="table-custom small">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>User</th>
                        <th>Action</th>
                        <th>Remarks</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model.History)
                    {
                        <tr>
                            <td>@log.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@(log.Actor?.Name ?? "System")</td>
                            <td class="font-weight-bold">@log.Action</td>
                            <td class="text-muted">@log.Remarks</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@{
    ViewData["Title"] = "Submit Manuscript";
}

<div class="row">
    <!-- Sidebar navigation -->
    <div class="col-md-3">
        <div class="dashboard-sidebar">
            <h4 class="font-weight-bold text-dark mb-4" style="font-family: var(--serif-font);">Author Panel</h4>
            <a asp-controller="Author" asp-action="Dashboard" class="sidebar-nav-link">My Submissions</a>
            <a asp-controller="Author" asp-action="Submit" class="sidebar-nav-link active">Submit New Paper</a>
            <hr />
            <a asp-controller="Dashboard" asp-action="Index" class="sidebar-nav-link">Home Dashboard</a>
        </div>
    </div>

    <!-- Main board -->
    <div class="col-md-9">
        <div class="dashboard-card">
            <h2 class="section-title">Submit a New Manuscript</h2>

            <div class="alert alert-info">
                Please make sure your manuscript is anonymized to comply with our double-blind review process. Remove any author names, academic affiliations, or identifiers from the body and properties of the uploaded PDF file.
            </div>

            <form asp-controller="Author" asp-action="Submit" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-group-custom">
                    <label class="form-label-custom" for="title">Article Title</label>
                    <input type="text" id="title" name="title" class="form-input-custom" required placeholder="Enter the complete title of your paper" />
                </div>

                <div class="form-group-custom">
                    <label class="form-label-custom" for="abstract">Abstract</label>
                    <textarea id="abstract" name="abstract" rows="8" class="form-input-custom" required placeholder="Paste your article abstract here (around 150-250 words)"></textarea>
                </div>

                <div class="form-group-custom">
                    <label class="form-label-custom" for="pdfFile">Manuscript File (PDF format only)</label>
                    <input type="file" id="pdfFile" name="pdfFile" class="form-control" accept="application/pdf" required />
                    <span class="text-muted small">Max file size: 20 MB. PDF file names should not contain author details.</span>
                </div>

                <div class="mt-4 text-end">
                    <a asp-controller="Author" asp-action="Dashboard" class="btn-secondary-custom me-2">Cancel</a>
                    <button type="submit" class="btn-primary-custom">Submit Manuscript</button>
                </div>
            </form>
        </div>
    </div>
</div>

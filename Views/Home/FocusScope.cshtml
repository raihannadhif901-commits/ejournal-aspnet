@{
    ViewData["Title"] = "Focus and Scope - Aims & Research Topics";
}

<div class="row justify-content-center">
    <div class="col-md-9">
        <h2 class="section-title">Focus & Scope</h2>
        <p class="lead text-muted mb-4">The Journal of Edge Computing serves as a global forum for the presentation of novel architectures, frameworks, protocols, and theoretical algorithms targeting decentralized nodes near endpoints.</p>
        
        <h4 class="font-weight-bold text-dark mt-4" style="font-family: var(--serif-font);">Core Thematic Areas:</h4>
        <ul class="lh-lg text-dark pl-3 mt-3">
            <li><strong>Distributed Compilers & Execution Nodes:</strong> Designing code optimization models for low-power edge gateways.</li>
            <li><strong>Latency & Resource Optimization:</strong> Novel caching strategies, offloading routing metrics, and dynamic bandwidth allocation.</li>
            <li><strong>Security, Isolation & Sandboxing:</strong> Micro-virtualization, WebAssembly at the edge, and lightweight cryptographic handshakes.</li>
            <li><strong>Edge AI & Federated Learning:</strong> On-device inference, decentralized model training, and privacy-preserving data aggregation.</li>
            <li><strong>Real-time IoT Architectures:</strong> High-throughput sensor telemetry grids and wireless networking protocols (5G/6G integrations).</li>
        </ul>

        <div class="alert alert-info mt-4">
            <strong>Open Access Policy:</strong> All articles published in our journal are made immediately available worldwide under an open-access license, with no fees charged to authors during submission or publication.
        </div>
    </div>
</div>

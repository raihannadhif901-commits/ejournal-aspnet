@{
    ViewData["Title"] = "Editorial Board & Committee Members";
}

<div class="row justify-content-center">
    <div class="col-md-9">
        <h2 class="section-title">Editorial Team</h2>
        <p class="text-muted mb-4">Our international board of editors guides the peer-review policies and maintains the scholarly rigor of the Journal of Edge Computing.</p>

        <h4 class="font-weight-bold text-dark mt-4 mb-3" style="font-family: var(--serif-font);">Editor-in-Chief</h4>
        <div class="mb-4">
            <h6 class="font-weight-bold text-dark mb-0">Prof. Elizabeth Carter, PhD</h6>
            <p class="text-muted small">Department of Distributed Systems, Boston Institute of Technology, USA</p>
        </div>

        <h4 class="font-weight-bold text-dark mt-4 mb-3" style="font-family: var(--serif-font);">Associate Editors</h4>
        <div class="row">
            <div class="col-md-6 mb-3">
                <h6 class="font-weight-bold text-dark mb-0">Dr. Akira Sato, PhD</h6>
                <p class="text-muted small">School of Information Engineering, Kyoto Technology Institute, Japan</p>
            </div>
            <div class="col-md-6 mb-3">
                <h6 class="font-weight-bold text-dark mb-0">Dr. Carlos Ruiz, PhD</h6>
                <p class="text-muted small">Embedded Systems Laboratory, Technical University of Madrid, Spain</p>
            </div>
            <div class="col-md-6 mb-3">
                <h6 class="font-weight-bold text-dark mb-0">Dr. Sarah Jenkins, PhD</h6>
                <p class="text-muted small">Institute of Advanced Computing, University of Oxford, UK</p>
            </div>
            <div class="col-md-6 mb-3">
                <h6 class="font-weight-bold text-dark mb-0">Prof. Lin Wei, PhD</h6>
                <p class="text-muted small">National Network Lab, Tsinghua University, China</p>
            </div>
        </div>

        <h4 class="font-weight-bold text-dark mt-4 mb-3" style="font-family: var(--serif-font);">Technical & Layout Editor</h4>
        <div class="mb-4">
            <h6 class="font-weight-bold text-dark mb-0">David Miller, MSc</h6>
            <p class="text-muted small">Office of Academic Publications, Edge Computing Press</p>
        </div>
    </div>
</div>

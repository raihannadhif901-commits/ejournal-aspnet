@{
    ViewData["Title"] = "Access Denied";
}

<div class="row justify-content-center text-center">
    <div class="col-md-7">
        <div class="dashboard-card py-5">
            <h1 class="text-danger mb-3" style="font-size: 4rem;">403</h1>
            <h2 class="section-title">Access Denied</h2>
            <p class="text-muted mb-4">You do not have permission to access this page. Academic workflows enforce strict role isolation to preserve review anonymity and process integrity.</p>
            <div>
                <a asp-controller="Dashboard" asp-action="Index" class="btn-primary-custom">Go to My Dashboard</a>
                <a asp-controller="Home" asp-action="Index" class="btn-secondary-custom ms-2">Return Home</a>
            </div>
        </div>
    </div>
</div>

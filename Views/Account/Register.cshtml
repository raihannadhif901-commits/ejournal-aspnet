@{
    ViewData["Title"] = "Author Registration";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="dashboard-card">
            <h2 class="section-title text-center">Author Registration</h2>
            
            <form asp-controller="Account" asp-action="Register" method="post">
                @Html.AntiForgeryToken()
                
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-group-custom">
                    <label class="form-label-custom" for="name">Full Name (with Academic Titles)</label>
                    <input type="text" id="name" name="name" class="form-input-custom" required placeholder="e.g. Dr. Jane Smith" />
                </div>

                <div class="form-group-custom">
                    <label class="form-label-custom" for="email">Email Address</label>
                    <input type="email" id="email" name="email" class="form-input-custom" required placeholder="e.g. janesmith@university.edu" />
                </div>

                <div class="form-group-custom">
                    <label class="form-label-custom" for="password">Password</label>
                    <input type="password" id="password" name="password" class="form-input-custom" required placeholder="Min 6 characters" />
                </div>

                <div class="form-group-custom">
                    <label class="form-label-custom" for="confirmPassword">Confirm Password</label>
                    <input type="password" id="confirmPassword" name="confirmPassword" class="form-input-custom" required placeholder="Re-enter password" />
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn-primary-custom w-100">Register as Author</button>
                </div>
            </form>

            <div class="text-center mt-3">
                <span class="text-muted">Already registered?</span> 
                <a asp-controller="Account" asp-action="Login" class="text-dark font-weight-bold">Sign In</a>
            </div>
        </div>
    </div>
</div>

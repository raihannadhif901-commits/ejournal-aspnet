@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="dashboard-card">
            <h2 class="section-title text-center">Sign In</h2>
            
            <form asp-controller="Account" asp-action="Login" method="post" asp-route-returnUrl="@ViewData["ReturnUrl"]">
                @Html.AntiForgeryToken()
                
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-group-custom">
                    <label class="form-label-custom" for="email">Email Address</label>
                    <input type="email" id="email" name="email" class="form-input-custom" required placeholder="email@journal.com" />
                </div>

                <div class="form-group-custom">
                    <label class="form-label-custom" for="password">Password</label>
                    <input type="password" id="password" name="password" class="form-input-custom" required placeholder="••••••••" />
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn-primary-custom w-100">Sign In</button>
                </div>
            </form>

            <div class="text-center mt-3">
                <span class="text-muted">New author?</span> 
                <a asp-controller="Account" asp-action="Register" class="text-dark font-weight-bold">Register here</a>
            </div>
        </div>

        <!-- Hint card for local testing -->
        <div class="card bg-light mt-3">
            <div class="card-body p-3">
                <h6 class="font-weight-bold mb-2 text-primary">Demo Seed Accounts:</h6>
                <ul class="mb-0 text-muted small ps-3">
                    <li><strong>Editor:</strong> editor@journal.com / Editor123!</li>
                    <li><strong>Author:</strong> author@journal.com / Author123!</li>
                    <li><strong>Reviewer 1:</strong> reviewer1@journal.com / Reviewer123!</li>
                    <li><strong>Reviewer 2:</strong> reviewer2@journal.com / Reviewer123!</li>
                </ul>
            </div>
        </div>
    </div>
</div>

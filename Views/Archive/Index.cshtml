@model IEnumerable<EJournal.Models.Volume>
@{
    ViewData["Title"] = "Journal Archives & Past Published Issues";
}

<div class="row justify-content-center">
    <div class="col-md-9">
        <h2 class="section-title">Archives</h2>
        
        <p class="text-muted mb-4">Explore previous volumes and issues of the Journal of Edge Computing. All articles are published open access.</p>

        @if (!Model.Any())
        {
            <div class="alert alert-secondary">
                No issues have been published yet. Check back soon for our inaugural volume.
            </div>
        }
        else
        {
            <div class="list-group mt-3">
                @foreach (var volume in Model)
                {
                    <a asp-controller="Archive" asp-action="Issue" asp-route-id="@volume.Id" 
                       class="list-group-item list-group-item-action p-4 mb-3" 
                       style="border: 1px solid var(--border-color); border-radius: 4px;">
                        <div class="d-flex w-100 justify-content-between align-items-center">
                            <h5 class="mb-1 text-primary font-weight-bold" style="font-family: var(--serif-font);">
                                Volume @volume.VolumeNumber, Issue @volume.IssueNumber (@volume.Year)
                            </h5>
                            <span class="text-muted small">
                                Published: @(volume.PublishedAt?.ToString("MMMM dd, yyyy") ?? "Recently")
                            </span>
                        </div>
                        <p class="mb-0 text-muted mt-2 small">
                            View the collection of research articles published in this issue.
                        </p>
                    </a>
                }
            </div>
        }
    </div>
</div>
